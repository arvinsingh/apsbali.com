{
  "name": "blog",
  "version": "3.1.0",
  "scripts": {
    "dev": "next dev --webpack",
    "predev": "pnpm run generate:content-manifests",
    "build": "pnpm run sync:content && NODE_ENV=production pnpm run generate:content-manifests && next build --webpack",
    "analyze": "ANALYZE=true pnpm run build",
    "start": "next start",
    "lint": "eslint . && prettier --check '**/*.{js,ts,tsx,jsx,md,mdx}' --log-level warn",
    "format": "prettier --write '**/*.{js,ts,tsx,jsx,md,mdx}'",
    "generate:content-manifests": "node scripts/generate-content-manifests.mjs",
    "sync:content": "sh -c 'if [ -n \"$GIT_SUBMODULE_TOKEN\" ]; then git config --global url.\"https://$GIT_SUBMODULE_TOKEN@github.com/\".insteadOf https://github.com/; fi && git submodule update --init --recursive'"
  },
  "pre-commit": "lint",
  "license": "MIT",
  "dependencies": {
    "@fec/remark-a11y-emoji": "4.0.2",
    "@mdx-js/react": "3.1.1",
    "@next/bundle-analyzer": "16.2.10",
    "@radix-ui/react-tabs": "^1.1.16",
    "@supabase/supabase-js": "2.110.0",
    "@vercel/analytics": "1.4.1",
    "bright": "1.0.0",
    "geist": "^1.7.2",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "next-mdx-remote": "6.0.0",
    "next-themes": "0.4.6",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "react": "19.2.7",
    "react-diff-viewer": "3.1.1",
    "react-dom": "19.2.7",
    "react-pdf": "^9.2.1",
    "react-tweet": "3.3.1",
    "rehype-highlight": "7.0.2",
    "rehype-img-size": "1.0.1",
    "remark-frontmatter": "5.0.0",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-toc": "9.0.0"
  },
  "devDependencies": {
    "@types/mdx": "2.0.14",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "clsx": "2.1.1",
    "critters": "0.0.20",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-mdx": "3.8.1",
    "gray-matter": "4.0.3",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-hover-media-feature": "1.0.2",
    "postcss-nested": "6.0.1",
    "postcss-preset-env": "9.1.4",
    "rehype-autolink-headings": "7.1.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "ts-node": "10.9.2",
    "typescript": "^5.9.3",
    "typescript-plugin-css-modules": "5.2.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "pnpm": {
    "overrides": {
      "@babel/runtime@7": "7.29.7",
      "ajv@6": "6.15.0",
      "brace-expansion@1": "1.1.15",
      "diff@4": "4.0.4",
      "flatted@3": "3.4.2",
      "js-yaml@3": "3.15.0",
      "js-yaml@4": "4.3.0",
      "minimatch@3": "3.1.5",
      "postcss@8": "8.5.16",
      "tar-fs@2": "2.1.4",
      "yaml@1": "1.10.3"
    }
  },
  "next-unused": {
    "alias": {
      "@components": "components/",
      "@data": "data/",
      "@lib": "lib/",
      "@styles": "styles/"
    },
    "include": [
      "components",
      "lib"
    ]
  }
}
